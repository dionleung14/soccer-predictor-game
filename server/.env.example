PORT=4000
CLIENT_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
FOOTBALL_DATA_API_TOKEN=
SESSION_SECRET=

# Optional Heroku-style URL (used only when DB_NAME is unset)
# DATABASE_URL=mysql://soccer:soccer@127.0.0.1:3306/soccer_predictor
MYSQL_SSL=false

# Local MySQL (preferred for local development)
DB_NAME="soccer_predictor_game"
DB_USERNAME_ROOT="root"
DB_PASSWORD_ROOT=""
DB_HOST=127.0.0.1
DB_PORT=3306

# On Heroku, prefer the add-on URL (set automatically by JawsDB / ClearDB):
# JAWSDB_URL=mysql://user:pass@host:3306/dbname
# CLEARDB_DATABASE_URL=mysql://user:pass@host/dbname?reconnect=true

# Fixture cache / future daily refresh
FIXTURES_SYNC_STALE_HOURS=24
# Optional: require this token for POST /api/competitions/:code/sync
# FIXTURES_SYNC_TOKEN=

# Signup emails — required in production / on Heroku (failed send blocks account creation).
# Local development skips SMTP unless FORCE_SIGNUP_EMAIL_LOCALLY is flipped in mailer.js.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From address shown to recipients (defaults to SMTP_USER when unset)
EMAIL_FROM="Soccer Predictor <noreply@example.com>"

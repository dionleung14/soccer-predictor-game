{
  "name": "soccer-predictor-game",
  "description": "Vite + Express monorepo with MySQL (JawsDB/ClearDB on Heroku)",
  "repository": "https://github.com/dionleung14/soccer-predictor-game",
  "addons": ["jawsdb:kitefin"],
  "buildpacks": [
    { "url": "heroku/nodejs" }
  ],
  "env": {
    "NODE_ENV": {
      "value": "production"
    },
    "FOOTBALL_DATA_API_TOKEN": {
      "description": "API token for api.football-data.org",
      "required": true
    },
    "SESSION_SECRET": {
      "description": "Secret used to sign session cookies",
      "generator": "secret"
    },
    "MYSQL_SSL": {
      "description": "Enable TLS for managed MySQL (recommended on Heroku)",
      "value": "true"
    },
    "FIXTURES_SYNC_TOKEN": {
      "description": "Optional token required for POST /api/competitions/:code/sync",
      "required": false
    },
    "SMTP_HOST": {
      "description": "SMTP host used to send signup emails (account creation requires a successful send)",
      "required": true
    },
    "SMTP_PORT": {
      "description": "SMTP port (587 STARTTLS or 465 SSL)",
      "value": "587"
    },
    "SMTP_SECURE": {
      "description": "Set true for SMTPS (port 465)",
      "value": "false"
    },
    "SMTP_USER": {
      "description": "SMTP username",
      "required": true
    },
    "SMTP_PASS": {
      "description": "SMTP password or app password",
      "required": true
    },
    "EMAIL_FROM": {
      "description": "From header for outbound mail, e.g. Soccer Predictor <noreply@example.com>",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "eco"
    }
  }
}

{
  "name": "soccer-predictor-game",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "db:migrate": "npm run db:migrate -w server",
    "fixtures:sync": "npm run fixtures:sync -w server",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "heroku-postbuild": "npm run build -w client",
    "lint": "npm run lint -w client"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
